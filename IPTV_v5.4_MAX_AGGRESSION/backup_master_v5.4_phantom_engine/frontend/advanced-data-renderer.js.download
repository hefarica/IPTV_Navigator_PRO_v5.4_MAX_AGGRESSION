  /**
   * Obtiene campos por defecto (balanceado para mostrar más información)
   */
  getDefaultFields() {
    return [
      'id',
      'name',
      'group',
      'resolution',
      'bitrate',
      'codec',
      'frames',
      'qualityScore',
      'scoreLive',
      'qualityTier',
      'qualityTags',
      'isSports',
      'isMovie',
      'type',
      'logo',
      'country',
      'language'
    ];
  }

  /**
   * Obtiene valor de campo, buscando en sinónimos automáticamente
   * ✅ V4.6: Usa modelo de 4 capas (tech > base > heuristics > legacy)
   * ✅ V4.7: Respeta fieldSourcePolicy para overrides por campo
   */
  getFieldValue(channel, fieldKey) {
    if (!channel) return null;

    const fieldDef = this.allFields[fieldKey];
    if (!fieldDef) return null;

    // ✅ V4.7: Check if field has a specific source override
    const sourceOverride = this.getFieldSource(fieldKey);
    if (sourceOverride && sourceOverride !== 'auto') {
      const overrideValue = this.resolveFromSource(channel, fieldKey, sourceOverride);
      if (overrideValue !== null) {
        return overrideValue;
      }
      // If override source has no value, fall through to auto
    }

    // ✅ V4.6: Extract layers (fallback hierarchy)
    const tech = channel.tech || {};
    const base = channel.base || {};
    const heuristics = channel.heuristics || {};
    const raw = base.raw || channel.raw || {};

    // ✅ V4.6: Special handling for derived fields from heuristics
    if (fieldKey === 'qualityScore') {
      return tech.qualityScore ?? heuristics.qualityScore ?? channel.qualityScore ?? 0;
    }
    if (fieldKey === 'qualityTier') {
      return tech.qualityTier ?? heuristics.qualityTier ?? channel.qualityTier ?? 'LOW';
    }
    if (fieldKey === 'qualityTags') {
      return heuristics.qualityTags ?? channel.qualityTags ?? [];
    }
    if (fieldKey === 'isUHD' || fieldKey === 'isHD' || fieldKey === 'isSD' ||
      fieldKey === 'isSports' || fieldKey === 'isMovie' || fieldKey === 'isSeries') {
      return heuristics[fieldKey] ?? channel[fieldKey] ?? false;
    }

    // ✅ V4.6: Resolution - priority: tech > base > heuristics > inferred
    if (fieldKey === 'resolution') {
      if (tech.resolutionLabel) return tech.resolutionLabel;
      if (tech.width && tech.height) return `${tech.width}x${tech.height}`;
      if (base.resolution) return base.resolution;
      if (heuristics.resolution) return heuristics.resolution;

      const w = raw.video_width || channel.video_width;
      const h = raw.video_height || channel.video_height;
      if (w && h && Number(w) > 0 && Number(h) > 0) return `${w}x${h}`;
      if (h && Number(h) > 0) return `${h}p`;
      if (channel.resolution) return channel.resolution;
      return null;
    }

    // ✅ V4.6: Core quality fields - priority: tech > base > heuristics > legacy
    if (fieldKey === 'codec') {
      return tech.codec ?? base.codec ?? heuristics.codec ?? channel.codec ?? null;
    }
    if (fieldKey === 'bitrate') {
      return tech.bitrateKbps ?? base.bitrate ?? heuristics.bitrate ?? channel.bitrate ?? 0;
    }
    if (fieldKey === 'frames') {
      return tech.fps ?? base.fps ?? heuristics.fps ?? channel.frames ?? null;
    }

    // ✅ V4.6: Geographic fields
    if (fieldKey === 'country') {
      return tech.country ?? base.country ?? heuristics.country ?? channel.country ?? 'INT';
    }
    if (fieldKey === 'language') {
      return tech.language ?? base.language ?? heuristics.language ?? channel.language ?? 'MIX';
    }

    // ✅ V4.6: Identity fields - priority: base > legacy
    if (fieldKey === 'name') return base.name ?? channel.name ?? '';
    if (fieldKey === 'group') return base.group ?? channel.group ?? '';
    if (fieldKey === 'logo') return base.logo ?? channel.logo ?? channel.stream_icon ?? '';
    if (fieldKey === 'url') return base.url ?? channel.url ?? '';
    if (fieldKey === 'type') return base.type ?? channel.type ?? 'live';

    // Intentar campo directo
    if (channel[fieldKey] !== undefined && channel[fieldKey] !== null && channel[fieldKey] !== '') {
      return channel[fieldKey];
    }

    // Buscar en sinónimos con prioridad de capas
    for (const synonym of (fieldDef.synonyms || [])) {
      const parts = synonym.split('.');

      if (parts.length === 1) {
        if (tech[synonym] !== undefined) return tech[synonym];
        if (base[synonym] !== undefined) return base[synonym];
        if (heuristics[synonym] !== undefined) return heuristics[synonym];
        if (channel[synonym] !== undefined && channel[synonym] !== null && channel[synonym] !== '') {
          return channel[synonym];
        }
      } else if (parts.length === 2 && parts[0] === 'raw') {
        if (raw[parts[1]] !== undefined && raw[parts[1]] !== null && raw[parts[1]] !== '') {
          return raw[parts[1]];
        }
      }
    }

    return null;
  }

  /**
   * Renderiza fila de tabla con todos los datos disponibles
   */
  renderTableRow(channel, container, selectedFields = null) {
    const fieldsToShow = selectedFields || this.selectedFields;
    const row = document.createElement('tr');

    fieldsToShow.forEach(fieldKey => {
      const fieldDef = this.allFields[fieldKey];
      if (!fieldDef) return;

      const cell = document.createElement('td');
      const value = this.getFieldValue(channel, fieldKey);

      // Formatear según tipo
      let displayValue = '';

      if (value === null || value === undefined || value === '') {
        displayValue = '—';
        cell.style.opacity = '0.5';
      } else {
        displayValue = this.formatValue(value, fieldDef.type, fieldDef.options);
      }

      cell.innerHTML = displayValue;
      cell.title = `${fieldDef.label}: ${fieldDef.category}`;

      // Colores para scoring
      if (fieldDef.isScoringMetric) {
        cell.style.fontWeight = 'bold';

        if (fieldKey === 'qualityScore') {
          const score = parseInt(value);
          if (score >= 90) cell.style.color = '#00FF00';
          else if (score >= 75) cell.style.color = '#00DD00';
          else if (score >= 55) cell.style.color = '#FF9900';
          else cell.style.color = '#FF6600';
        } else if (fieldKey === 'qualityTier') {
          if (value === 'ULTRA') cell.style.color = '#FFD700';
          else if (value === 'HIGH') cell.style.color = '#00FF00';
          else if (value === 'MEDIUM') cell.style.color = '#FF9900';
          else cell.style.color = '#FF6600';
        }
      }

      row.appendChild(cell);
    });

    container.appendChild(row);
  }

  /**
   * Formatea valor según tipo de campo
   */
  formatValue(value, type, options) {
    if (value === null || value === undefined) return '—';

    switch (type) {
      case 'boolean':
        return value ? '✓' : '✗';

      case 'number':
        return typeof value === 'number' ? value.toLocaleString() : value;

      case 'image':
        if (value) {
          return `<img src="${value}" style="max-width:60px; max-height:30px; border-radius:2px;" alt="logo" onerror="this.style.display='none'">`;
        }
        return '—';

      case 'url':
        const urlStr = String(value);
        if (urlStr.startsWith('http')) {
          return `<a href="${urlStr}" target="_blank" style="color:#0099FF; text-decoration:underline;">🔗</a>`;
        }
        return urlStr.substring(0, 30) + (urlStr.length > 30 ? '...' : '');

      case 'tags':
        if (Array.isArray(value)) {
          return value.map(tag => `<span style="background:#333; color:#0FF; padding:2px 6px; border-radius:3px; margin-right:3px; font-size:11px;">${tag}</span>`).join('');
        }
        return value;

      case 'text':
        const text = String(value);
        return text.substring(0, 50) + (text.length > 50 ? '...' : '');

      case 'date':
        if (typeof value === 'number') {
          return new Date(value).toLocaleDateString();
        }
        return String(value);

      case 'select':
        return `<strong>${value}</strong>`;

      default:
        return String(value).substring(0, 50);
    }
  }

  /**
   * Obtiene todos los campos disponibles agrupados por categoría
   */
  getAllFieldsGrouped() {
    const grouped = {};

    Object.entries(this.allFields).forEach(([key, def]) => {
      if (!grouped[def.category]) {
        grouped[def.category] = [];
      }
      grouped[def.category].push({
        key,
        label: def.label,
        importance: def.importance,
        type: def.type,
        synonymCount: def.synonyms.length
      });
    });

    return grouped;
  }

  /**
   * Genera selector de columnas para UI
   * ✅ V4.7: Incluye selector de fuente por campo
   */
  generateColumnSelector() {
    const grouped = this.getAllFieldsGrouped();
    const html = [];

    html.push('<div style="background:#1a1a1a; border:1px solid #333; border-radius:6px; padding:12px; max-height:500px; overflow-y:auto;">');

    // Header with legend
    html.push(`
      <div style="margin-bottom:10px; padding-bottom:8px; border-bottom:1px solid #333;">
        <span style="color:#888; font-size:10px;">
          Fuentes: 🔵Auto | 🔌Srv | 🔄Heur | 📡Prb | 🌐Ext
        </span>
      </div>
    `);

    Object.entries(grouped).forEach(([category, fields]) => {
      html.push(`<div style="margin-bottom:12px;">`);
      html.push(`<strong style="display:block; color:#0FF; margin-bottom:6px; font-size:12px;">📁 ${category}</strong>`);

      fields.forEach(field => {
        const isSelected = this.selectedFields.includes(field.key);
        const importance = field.importance === 'critical' ? '🔴' : field.importance === 'high' ? '🟠' : '🟡';
        const currentSource = this.getFieldSource(field.key);

        // Check if field supports multiple sources (quality/geo fields do)
        const supportsSourceSelector = ['resolution', 'bitrate', 'codec', 'frames', 'country', 'language', 'logo', 'name', 'group'].includes(field.key);

        html.push(`
          <div style="display:flex; align-items:center; padding:4px 0; gap:6px; flex-wrap:wrap;">
            <label style="flex:0 0 auto; cursor:pointer; font-size:11px; min-width:180px;">
              <input type="checkbox" 
                data-field="${field.key}" 
                ${isSelected ? 'checked' : ''} 
                onchange="window.app.advancedDataRenderer.toggleField('${field.key}')"
                style="cursor:pointer; margin-right:4px;">
              ${importance} ${field.label}
            </label>
            ${supportsSourceSelector ? `
              <span style="display:flex; gap:2px; font-size:9px;">
                <label style="cursor:pointer; padding:2px 4px; border-radius:3px; background:${currentSource === 'auto' ? '#38bdf8' : '#333'}; color:${currentSource === 'auto' ? '#000' : '#888'};">
                  <input type="radio" name="src_${field.key}" value="auto" ${currentSource === 'auto' ? 'checked' : ''} 
                    onchange="window.app.advancedDataRenderer.setFieldSource('${field.key}', 'auto')" style="display:none;">A
                </label>
                <label style="cursor:pointer; padding:2px 4px; border-radius:3px; background:${currentSource === 'server' ? '#4ade80' : '#333'}; color:${currentSource === 'server' ? '#000' : '#888'};">
                  <input type="radio" name="src_${field.key}" value="server" ${currentSource === 'server' ? 'checked' : ''} 
                    onchange="window.app.advancedDataRenderer.setFieldSource('${field.key}', 'server')" style="display:none;">S
                </label>
                <label style="cursor:pointer; padding:2px 4px; border-radius:3px; background:${currentSource === 'heuristics' ? '#fbbf24' : '#333'}; color:${currentSource === 'heuristics' ? '#000' : '#888'};">
                  <input type="radio" name="src_${field.key}" value="heuristics" ${currentSource === 'heuristics' ? 'checked' : ''} 
                    onchange="window.app.advancedDataRenderer.setFieldSource('${field.key}', 'heuristics')" style="display:none;">H
                </label>
                <label style="cursor:pointer; padding:2px 4px; border-radius:3px; background:${currentSource === 'probe' ? '#f472b6' : '#333'}; color:${currentSource === 'probe' ? '#000' : '#888'};">
                  <input type="radio" name="src_${field.key}" value="probe" ${currentSource === 'probe' ? 'checked' : ''} 
                    onchange="window.app.advancedDataRenderer.setFieldSource('${field.key}', 'probe')" style="display:none;">P
                </label>
                <label style="cursor:pointer; padding:2px 4px; border-radius:3px; background:${currentSource === 'external' ? '#a78bfa' : '#333'}; color:${currentSource === 'external' ? '#000' : '#888'};">
                  <input type="radio" name="src_${field.key}" value="external" ${currentSource === 'external' ? 'checked' : ''} 
                    onchange="window.app.advancedDataRenderer.setFieldSource('${field.key}', 'external')" style="display:none;">E
                </label>
              </span>
            ` : ''}
          </div>
        `);
      });

      html.push('</div>');
    });

    html.push('</div>');

    return html.join('');
  }

  /**
   * ✅ V4.7: Set source and refresh table
   */
  setFieldSource(fieldKey, source) {
    if (source === 'auto') {
      delete this.fieldSourcePolicy[fieldKey];
    } else {
      this.fieldSourcePolicy[fieldKey] = source;
    }
    this.saveFieldSourcePolicy();

    // Refresh table
    if (this.app && this.app.renderTable) {
      this.app.renderTable();
    }
  }

  /**
   * Toggle selección de campo
   */
  toggleField(fieldKey) {
    const idx = this.selectedFields.indexOf(fieldKey);
    if (idx > -1) {
      this.selectedFields.splice(idx, 1);
    } else {
      this.selectedFields.push(fieldKey);
    }

    // Re-renderizar tabla
    if (this.app && this.app.renderTable) {
      this.app.renderTable();
    }
  }

  /**
   * Obtiene estadísticas de cobertura
   */
  getCoverageStats(channels) {
    if (!Array.isArray(channels) || channels.length === 0) {
      return { totalFields: Object.keys(this.allFields).length, coverage: {} };
    }

    const coverage = {};
    let fieldsCovered = 0;

    Object.keys(this.allFields).forEach(fieldKey => {
      let fieldPresent = 0;

      channels.forEach(ch => {
        const value = this.getFieldValue(ch, fieldKey);
        if (value !== null && value !== undefined && value !== '') {
          fieldPresent++;
        }
      });

      const percentage = (fieldPresent / channels.length) * 100;
      coverage[fieldKey] = {
        present: fieldPresent,
        percentage: percentage.toFixed(1),
        label: this.allFields[fieldKey].label
      };

      if (percentage > 0) fieldsCovered++;
    });

    return {
      totalFields: Object.keys(this.allFields).length,
      fieldsCovered,
      coverage
    };
  }
}

// Inicializar globalmente
if (typeof window !== 'undefined') {
  window.AdvancedDataRenderer = AdvancedDataRenderer;
}
