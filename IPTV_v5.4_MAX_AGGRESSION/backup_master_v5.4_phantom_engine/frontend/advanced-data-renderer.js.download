/**
 * advanced-data-renderer.js
 * 
 * ✅ Renderizador avanzado de datos para IPTV Navigator PRO v4.5.1
 * 
 * CARACTERÍSTICAS:
 * - Renderiza TODA la data disponible en tabla HTML existente
 * - Homologa y relaciona sinónimos automáticamente
 * - NO modifica HTML ni CSS
 * - Funciona con arrays dinámicos de campos
 * - Selección personalizada de columnas
 * - Scoring fundamental integrado (Calidad, Transmisión, Estabilidad)
 */

class AdvancedDataRenderer {
  constructor(appInstance) {
    this.app = appInstance;
    this.allFields = this.buildAllFields();
    this.selectedFields = this.getDefaultFields();
    this.qualityWeights = {
      resolution: 0.35,
      bitrate: 0.25,
      codec: 0.20,
      frames: 0.10,
      stability: 0.10
    };

    // ═══════════════════════════════════════════════════════════════════
    // ✅ V4.8: ADVANCED FIELD SOURCE POLICY
    // Supports two modes:
    //   - "fixed": uses ONLY one specific source
    //   - "priority": uses a fallback chain of sources
    // ═══════════════════════════════════════════════════════════════════

    this.fieldSourcePolicy = this.loadFieldSourcePolicy();

    // Default policy (used when user hasn't customized)
    this.DEFAULT_FIELD_SOURCE_POLICY = {
      // Identity - always from server
      id: { mode: "fixed", source: "base" },
      name: { mode: "fixed", source: "base" },
      group: { mode: "fixed", source: "base" },
      logo: { mode: "priority", order: ["base", "external"] },

      // Quality - tech (probe) has priority, then inference
      resolution: { mode: "priority", order: ["tech", "heuristics", "base"] },
      bitrate: { mode: "priority", order: ["tech", "heuristics", "base"] },
      codec: { mode: "priority", order: ["tech", "heuristics", "base"] },
      codecFamily: { mode: "fixed", source: "heuristics" },
      fps: { mode: "fixed", source: "tech" },
      frames: { mode: "fixed", source: "tech" },

      // Geographic - external has best data
      country: { mode: "priority", order: ["external", "heuristics", "base"] },
      language: { mode: "priority", order: ["external", "heuristics", "base"] },
      timezone: { mode: "fixed", source: "base" },

      // Scoring - always from heuristics
      qualityScore: { mode: "fixed", source: "heuristics" },
      qualityTier: { mode: "fixed", source: "heuristics" },

      // Infrastructure - always from server
      serverUrl: { mode: "fixed", source: "base" },
      url: { mode: "fixed", source: "base" },
      port: { mode: "fixed", source: "base" },
      portHttps: { mode: "fixed", source: "base" },
      portRtmp: { mode: "fixed", source: "base" },
      protocol: { mode: "fixed", source: "base" },
      serverName: { mode: "fixed", source: "base" },

      // Metadata
      rawNum: { mode: "fixed", source: "base" },
      'raw.num': { mode: "fixed", source: "base" },
      structure: { mode: "fixed", source: "base" },

      // External enrichment - IPTV-org, TDT, etc.
      website: { mode: "fixed", source: "external" },
      year: { mode: "fixed", source: "external" },
      year_launched: { mode: "fixed", source: "external" },
      network: { mode: "fixed", source: "external" },
      owner: { mode: "fixed", source: "external" },
      categories: { mode: "fixed", source: "external" },
      tvArchive: { mode: "priority", order: ["base", "external"] },
      epgChannelId: { mode: "priority", order: ["external", "base"] },
      is_nsfw: { mode: "priority", order: ["external", "heuristics", "base"] }
    };
  }

  // ═══════════════════════════════════════════════════════════════════
  // V4.8: LOAD / SAVE POLICY
  // ═══════════════════════════════════════════════════════════════════

  loadFieldSourcePolicy() {
    try {
      const saved = localStorage.getItem('iptv_fieldSourcePolicy');
      return saved ? JSON.parse(saved) : {};
    } catch (e) {
      console.warn('⚠️ Error loading fieldSourcePolicy:', e);
      return {};
    }
  }

  saveFieldSourcePolicy() {
    try {
      localStorage.setItem('iptv_fieldSourcePolicy', JSON.stringify(this.fieldSourcePolicy));
    } catch (e) {
      console.warn('⚠️ Error saving fieldSourcePolicy:', e);
    }
  }

  // ═══════════════════════════════════════════════════════════════════
  // V4.8: SET / GET POLICY FOR A FIELD
  // ═══════════════════════════════════════════════════════════════════

  /**
   * Set source policy for a field
   * @param {string} fieldKey - Field name
   * @param {string} source - 'auto', 'base', 'server', 'heuristics', 'tech', 'probe', 'external'
   */
  setFieldSource(fieldKey, source) {
    // Normalize source aliases
    const sourceMap = {
      'server': 'base',
      'probe': 'tech'
    };
    const normalizedSource = sourceMap[source] || source;

    if (source === 'auto') {
      // Remove custom override, revert to default
      delete this.fieldSourcePolicy[fieldKey];
    } else {
      // Set fixed mode with specific source
      this.fieldSourcePolicy[fieldKey] = { mode: "fixed", source: normalizedSource };
    }

    this.saveFieldSourcePolicy();
    console.log(`🔧 Field "${fieldKey}" source set to: ${normalizedSource}`);

    // Sync with global FieldSourcePolicy if available
    if (window.FieldSourcePolicy && typeof window.FieldSourcePolicy.setPolicy === 'function') {
      const policyUpdate = {};
      policyUpdate[fieldKey] = [normalizedSource];
      window.FieldSourcePolicy.setPolicy(policyUpdate);
    }

    // Trigger table refresh if app is available
    if (this.app && typeof this.app.applyFilters === 'function') {
      this.app.applyFilters();
    }
  }

  /**
   * Get current source for a field
   * @param {string} fieldKey - Field name
   * @returns {string} Current source or 'auto'
   */
  getFieldSource(fieldKey) {
    const custom = this.fieldSourcePolicy[fieldKey];
    if (custom && custom.mode === 'fixed') {
      return custom.source;
    }
    return 'auto';
  }

  /**
   * Get the effective policy for a field (custom or default)
   * @param {string} fieldKey - Field name
   * @returns {Object|null} Policy object or null
   */
  getEffectivePolicy(fieldKey) {
    return this.fieldSourcePolicy[fieldKey] || this.DEFAULT_FIELD_SOURCE_POLICY[fieldKey] || null;
  }

  // ═══════════════════════════════════════════════════════════════════
  // V4.8: RESOLVE FIELD VALUE USING POLICY
  // ═══════════════════════════════════════════════════════════════════

  /**
   * Get a value from a specific source layer
   * Supports nested paths like 'external.probe-rosa' or 'external.iptv-org'
   * @param {Object} channel - Channel object with base, heuristics, tech, external layers
   * @param {string} key - Field key to retrieve
   * @param {string} source - Source layer name or path (e.g., 'base', 'external.probe-rosa')
   * @returns {*} Value or null
   */
  getValueFromSource(channel, key, source) {
    if (!channel) return null;

    // Handle nested paths like 'external.probe-rosa'
    if (source.includes('.')) {
      const parts = source.split('.');
      let data = channel;
      for (const part of parts) {
        data = data?.[part];
        if (data === undefined || data === null) return null;
      }
      return data?.[key] ?? null;
    }

    // Standard source resolution
    switch (source) {
      case 'base':
      case 'server':
        return channel.base?.[key] ?? channel.raw?.[key] ?? channel[key] ?? null;

      case 'heuristics':
        return channel.heuristics?.[key] ?? null;

      case 'tech':
      case 'probe':
        // Special mappings for tech layer
        if (key === 'resolution') {
          const tech = channel.tech || {};
          return tech.resolutionLabel || (tech.width && tech.height ? `${tech.width}x${tech.height}` : null);
        }
        if (key === 'bitrate') return channel.tech?.bitrateKbps ?? channel.tech?.bitrate ?? null;
        if (key === 'fps' || key === 'frames') return channel.tech?.fps ?? channel.tech?.frameRate ?? null;
        return channel.tech?.[key] ?? null;

      case 'external':
        return channel.external?.[key] ?? null;

      case 'raw':
        return channel.raw?.[key] ?? null;

      case 'quality':
        // For probe-rosa results stored in channel.quality
        return channel.quality?.[key] ?? null;

      default:
        return null;
    }
  }

  /**
   * Resolve a field value using the policy system
   * Supports modes: fixed, priority, best, fallback
   * @param {Object} channel - Channel object
   * @param {string} key - Field key
   * @returns {*} Resolved value
   */
  resolveField(channel, key) {
    const policy = this.getEffectivePolicy(key);

    if (!policy) {
      // No policy - use default hierarchy: tech > base > heuristics > external
      const defaultOrder = ['tech', 'base', 'heuristics', 'external'];
      for (const source of defaultOrder) {
        const value = this.getValueFromSource(channel, key, source);
        if (value !== undefined && value !== null && value !== '') {
          return value;
        }
      }
      return null;
    }

    // Get sources from policy
    const sources = policy.order || (policy.source ? [policy.source] : []);

    // --- FIXED MODE ---
    if (policy.mode === 'fixed' && policy.source) {
      return this.getValueFromSource(channel, key, policy.source);
    }

    // --- PRIORITY MODE (first valid value) ---
    if (policy.mode === 'priority' && Array.isArray(policy.order)) {
      for (const source of policy.order) {
        const value = this.getValueFromSource(channel, key, source);
        if (value !== undefined && value !== null && value !== '') {
          return value;
        }
      }
      return null;
    }

    // --- FALLBACK MODE (same as priority - first non-empty value) ---
    if (policy.mode === 'fallback' && Array.isArray(policy.order)) {
      for (const source of policy.order) {
        const value = this.getValueFromSource(channel, key, source);
        if (value !== undefined && value !== null && value !== '') {
          return value;
        }
      }
      return null;
    }

    // --- BEST MODE (selects highest numeric value) ---
    if (policy.mode === 'best' && Array.isArray(policy.order)) {
      const values = [];
      for (const source of policy.order) {
        const value = this.getValueFromSource(channel, key, source);
        if (value !== undefined && value !== null && value !== '') {
          const numValue = typeof value === 'number' ? value : parseFloat(value);
          if (!isNaN(numValue)) {
            values.push({ source, value: numValue, original: value });
          }
        }
      }
      if (values.length > 0) {
        // Return the highest numeric value
        values.sort((a, b) => b.value - a.value);
        return values[0].original;
      }
      return null;
    }

    return null;
  }

  // ✅ V4.7: Resolve value from a specific source layer
  // COMPREHENSIVE mapping for ALL 49+ fields across 4 sources
  resolveFromSource(channel, fieldKey, source) {
    if (!channel) return null;

    const base = channel.base || {};
    const heuristics = channel.heuristics || {};
    const tech = channel.tech || {};
    const external = channel.external || {};
    const raw = base.raw || channel.raw || {};
    const meta = channel.meta || {};

    // ═══════════════════════════════════════════════════════════════════
    // SOURCE-SPECIFIC EXTRACTION LOGIC
    // ═══════════════════════════════════════════════════════════════════

    // SERVER (base layer) - Datos directos del servidor API Xtream
    if (source === 'server') {
      const serverMappings = {
        // Identidad Nuclear
        'id': raw.stream_id || base.id || channel.id,
        'name': base.name || raw.name || channel.name,
        'tvgId': raw.tvg_id || raw.epg_channel_id,
        'tvgName': raw.tvg_name || raw.tvg_name,
        'raw.num': raw.num,

        // Calidad Multimedia
        'resolution': (() => {
          const w = raw.video_width || channel.video_width;
          const h = raw.video_height || channel.video_height;
          if (w && h && Number(w) > 0 && Number(h) > 0) return `${w}x${h}`;
          return base.resolution || null;
        })(),
        'bitrate': raw.bitrate || base.bitrate,
        'averageBitrate': raw.averageBitrate || base.averageBitrate,
        'bitrateTierCode': base.bitrateTierCode,
        'codec': raw.video_codec || base.codec,
        'frames': raw.fps || raw.frame_rate || base.fps,
        'raw.video_width': raw.video_width,
        'raw.video_height': raw.video_height,
        'raw.aspect_ratio': raw.aspect_ratio,
        'raw.audio_codec': raw.audio_codec,
        'raw.audio_channels': raw.audio_channels,

        // Categorización
        'group': base.group || raw.category_name || raw.group_title,
        'type': raw.stream_type || base.type,
        'is_adult': raw.is_adult,
        'rating': raw.rating,
        'raw.plot': raw.plot,
        'raw.cast': raw.cast,
        'raw.director': raw.director,

        // Infraestructura
        'serverName': channel.serverName,
        'url': base.url || raw.direct_source,
        'raw.container_extension': raw.container_extension,
        'raw.direct_source': raw.direct_source,
        'provider': channel.serverName,
        'raw.host': raw.host || channel.host,
        'raw.updated_at': raw.updated_at,
        'added': raw.added || raw.created_at,
        'raw.user_agent': raw.user_agent,

        // Geográfico
        'country': base.country,
        'language': base.language,
        'logo': raw.stream_icon || raw.cover || base.logo,
        'website': raw.website,
        'year_launched': raw.year_launched,
        'is_nsfw': raw.is_nsfw,

        // Legacy/Extras
        'tvarchive': raw.tv_archive || raw.catchup,
        'epg_url': raw.epg_url,
        'raw.tv_archive_duration': raw.tv_archive_duration
      };
      return serverMappings[fieldKey] !== undefined ? serverMappings[fieldKey] : null;
    }

    // HEURISTICS layer - Datos inferidos por reglas y patrones
    if (source === 'heuristics') {
      const heuristicMappings = {
        // Identidad
        'id': null, // No se infiere
        'name': heuristics.name,
        'tvgId': heuristics.tvgId,
        'tvgName': heuristics.tvgName,
        'raw.num': null,

        // Calidad - Inferida del nombre/grupo
        'resolution': heuristics.resolution,
        'bitrate': heuristics.bitrate,
        'averageBitrate': heuristics.averageBitrate,
        'bitrateTierCode': heuristics.bitrateTierCode,
        'codec': heuristics.codec,
        'frames': heuristics.fps || heuristics.frames,
        'raw.video_width': heuristics.width,
        'raw.video_height': heuristics.height,
        'raw.aspect_ratio': null,
        'raw.audio_codec': null,
        'raw.audio_channels': null,

        // Categorización
        'group': heuristics.group,
        'type': heuristics.type || heuristics.streamType,
        'is_adult': heuristics.is_adult || heuristics.isAdult,
        'rating': null,
        'raw.plot': null,
        'raw.cast': null,
        'raw.director': null,

        // Infraestructura - No se infiere
        'serverName': null,
        'url': null,
        'raw.container_extension': heuristics.format,
        'raw.direct_source': null,
        'provider': null,
        'raw.host': null,
        'raw.updated_at': null,
        'added': null,
        'raw.user_agent': null,

        // Geográfico - Principal fortaleza de heurísticas
        'country': heuristics.country,
        'language': heuristics.language,
        'logo': null,
        'website': null,
        'year_launched': null,
        'is_nsfw': heuristics.is_nsfw || heuristics.isNSFW,

        // Clasificación inferida
        'isSports': heuristics.isSports,
        'isNews': heuristics.isNews,
        'isMovieChannel': heuristics.isMovieChannel,
        'isMusicChannel': heuristics.isMusicChannel,
        'isKidsChannel': heuristics.isKidsChannel,

        // ✅ V4.10: Score Live y Tier desde heurísticas
        'scoreLive': heuristics.scoreLive,
        'qualityTier': heuristics.qualityTier,
        'qualityScore': heuristics.qualityScore,

        // Legacy
        'tvarchive': null,
        'epg_url': null,
        'raw.tv_archive_duration': null
      };
      return heuristicMappings[fieldKey] !== undefined ? heuristicMappings[fieldKey] : null;
    }

    // PROBE (tech layer) - Datos obtenidos de análisis técnico del stream
    if (source === 'probe') {
      const probeMappings = {
        // Identidad - No viene del probe
        'id': null,
        'name': null,
        'tvgId': null,
        'tvgName': null,
        'raw.num': null,

        // Calidad - Principal fortaleza del probe
        'resolution': tech.resolutionLabel || (tech.width && tech.height ? `${tech.width}x${tech.height}` : null),
        'bitrate': tech.bitrateKbps || tech.bitrate,
        'averageBitrate': tech.averageBitrate,
        'bitrateTierCode': tech.bitrateTier,
        'codec': tech.codec || tech.videoCodec,
        'frames': tech.fps || tech.frameRate,
        'raw.video_width': tech.width,
        'raw.video_height': tech.height,
        'raw.aspect_ratio': tech.aspectRatio,
        'raw.audio_codec': tech.audioCodec,
        'raw.audio_channels': tech.audioChannels,

        // Categorización - No viene del probe
        'group': null,
        'type': null,
        'is_adult': null,
        'rating': null,
        'raw.plot': null,
        'raw.cast': null,
        'raw.director': null,

        // Infraestructura - Del probe
        'serverName': null,
        'url': tech.url || tech.analyzedUrl,
        'raw.container_extension': tech.format || tech.container,
        'raw.direct_source': null,
        'provider': null,
        'raw.host': null,
        'raw.updated_at': null,
        'added': null,
        'raw.user_agent': null,

        // Geográfico - No viene del probe
        'country': null,
        'language': null,
        'logo': null,
        'website': null,
        'year_launched': null,
        'is_nsfw': null,

        // Métricas técnicas exclusivas del probe
        'latency': tech.latency,
        'streamHealth': tech.health,
        'probeTimestamp': tech.timestamp,
        'probed': meta.probed ? 'Sí' : 'No',

        // Legacy
        'tvarchive': null,
        'epg_url': null,
        'raw.tv_archive_duration': null
      };
      return probeMappings[fieldKey] !== undefined ? probeMappings[fieldKey] : null;
    }

    // EXTERNAL layer - Datos de IPTV-org o bases de datos externas
    if (source === 'external') {
      const externalMappings = {
        // Identidad
        'id': external.id || external.tvg_id,
        'name': external.name,
        'tvgId': external.tvg_id || external.id,
        'tvgName': external.name,
        'raw.num': null,

        // Calidad - Típicamente no está en fuentes externas
        'resolution': external.resolution,
        'bitrate': null,
        'averageBitrate': null,
        'bitrateTierCode': null,
        'codec': null,
        'frames': null,
        'raw.video_width': null,
        'raw.video_height': null,
        'raw.aspect_ratio': null,
        'raw.audio_codec': null,
        'raw.audio_channels': null,

        // Categorización
        'group': external.categories ? external.categories.join(', ') : external.group,
        'type': external.broadcast_type,
        'is_adult': external.is_nsfw,
        'rating': null,
        'raw.plot': null,
        'raw.cast': null,
        'raw.director': null,

        // Infraestructura
        'serverName': null,
        'url': external.url,
        'raw.container_extension': null,
        'raw.direct_source': null,
        'provider': external.network || external.owner,
        'raw.host': null,
        'raw.updated_at': null,
        'added': null,
        'raw.user_agent': null,

        // Geográfico - Principal fortaleza de datos externos
        'country': external.country,
        'language': external.language || (external.languages && external.languages[0]),
        'logo': external.logo,
        'website': external.website,
        'year_launched': external.launched,
        'is_nsfw': external.is_nsfw,

        // Legacy
        'tvarchive': null,
        'epg_url': null,
        'raw.tv_archive_duration': null
      };
      return externalMappings[fieldKey] !== undefined ? externalMappings[fieldKey] : null;
    }

    // AUTO or unknown source - return null to fall back to default hierarchy
    return null;
  }

  /**
   * Construye el mapeo COMPLETO de todos los campos disponibles
   * Homologa sinónimos y relaciona campos equivalentes
   */
  buildAllFields() {
    return {
      // IDENTIDAD NUCLEAR
      'id': {
        category: 'Identidad Nuclear',
        label: 'ID Único',
        synonyms: ['stream_id', 'streamid', 'epg_channel_id', 'channel_id', 'hash', 'raw.stream_id', 'raw.custom_sid'],
        type: 'string',
        importance: 'critical',
        group: 1
      },
      'name': {
        category: 'Identidad Nuclear',
        label: 'Nombre del Canal',
        synonyms: ['title', 'stream_name', 'channel_name'],
        type: 'string',
        importance: 'critical',
        group: 1
      },
      'tvgId': {
        category: 'Identidad Nuclear',
        label: 'TVG ID (EPG)',
        synonyms: ['tvg-id', 'tvg_id', 'epg_id', 'xmltv_id', 'channel_id_epg'],
        type: 'string',
        importance: 'high',
        group: 1
      },
      'tvgName': {
        category: 'Identidad Nuclear',
        label: 'TVG Nombre',
        synonyms: ['tvg-name', 'tvg_name', 'epg_name', 'xmltv_name'],
        type: 'string',
        importance: 'high',
        group: 1
      },
      'raw.num': {
        category: 'Identidad Nuclear',
        label: 'Número/Posición',
        synonyms: ['num', 'number', 'position', 'order'],
        type: 'number',
        importance: 'medium',
        group: 1
      },

      // CALIDAD DE IMAGEN Y SONIDO
      'resolution': {
        category: 'Calidad Multimedia',
        label: 'Resolución',
        synonyms: ['res', 'quality', 'video_quality', 'definition', 'video_res', 'display_height', 'raw.video_height'],
        type: 'select',
        options: ['8K', '4K', '1440p', '1080p', '720p', '480p', 'SD'],
        importance: 'critical',
        group: 2,
        qualityScore: true
      },
      'bitrate': {
        category: 'Calidad Multimedia',
        label: 'Bitrate (kbps)',
        synonyms: ['br', 'bps', 'bitrate_kbps', 'bit_rate', 'bitrate_kb', 'kbps'],
        type: 'number',
        importance: 'critical',
        group: 2,
        qualityScore: true
      },
      'averageBitrate': {
        category: 'Calidad Multimedia',
        label: 'Bitrate Promedio',
        synonyms: ['avgBitrate', 'avg_bitrate', 'average_bitrate', 'mean_bitrate'],
        type: 'number',
        importance: 'high',
        group: 2
      },
      'bitrateTierCode': {
        category: 'Calidad Multimedia',
        label: 'Tier Bitrate',
        synonyms: ['tier', 'quality_tier'],
        type: 'select',
        options: ['ULTRA', 'HIGH', 'MEDIUM', 'LOW'],
        importance: 'high',
        group: 2
      },
      'codec': {
        category: 'Calidad Multimedia',
        label: 'Codec Vídeo',
        synonyms: ['video_codec', 'stream_codec', 'vcodec'],
        type: 'select',
        options: ['HEVC', 'H264', 'AV1', 'VP9'],
        importance: 'critical',
        group: 2,
        qualityScore: true
      },
      'frames': {
        category: 'Calidad Multimedia',
        label: 'FPS',
        synonyms: ['frame_rate', 'framerate', 'fps', 'video_fps', 'vfr'],
        type: 'number',
        importance: 'high',
        group: 2,
        qualityScore: true
      },
      'raw.video_width': {
        category: 'Calidad Multimedia',
        label: 'Ancho Vídeo',
        synonyms: ['video_width', 'width', 'w'],
        type: 'number',
        importance: 'medium',
        group: 2
      },
      'raw.aspect_ratio': {
        category: 'Calidad Multimedia',
        label: 'Relación Aspecto',
        synonyms: ['aspect_ratio', 'aspect'],
        type: 'string',
        importance: 'medium',
        group: 2
      },
      'raw.audio_codec': {
        category: 'Calidad Multimedia',
        label: 'Codec Audio',
        synonyms: ['audio_codec', 'acodec'],
        type: 'string',
        importance: 'medium',
        group: 2
      },
      'raw.audio_channels': {
        category: 'Calidad Multimedia',
        label: 'Canales Audio',
