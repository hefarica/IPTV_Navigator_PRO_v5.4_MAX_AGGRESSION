# ============================================================================
# APE v15 ULTIMATE - Environment Configuration Template
# ============================================================================
# Copy this file to .env and customize for your deployment
# ============================================================================

# =============================================================================
# Server Configuration
# =============================================================================
APE_HOST=0.0.0.0
APE_PORT=8080
APE_LOG_LEVEL=INFO

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your_secure_password

# =============================================================================
# Telemetry Configuration
# =============================================================================
# Telemetry capture interval (milliseconds)
TELEMETRY_INTERVAL_MS=100
# Snapshot interval for macro-level analysis (seconds)
SNAPSHOT_INTERVAL_S=10
# Hysteresis window for failback (seconds)
HYSTERESIS_WINDOW_S=60

# =============================================================================
# Profile Configuration
# =============================================================================
# Default profile when none specified
DEFAULT_PROFILE=P2
# Available profiles (P0=8K Ultra, P1=4K 60fps, P2=4K, P3=FHD, P4=HD, P5=SD)
AVAILABLE_PROFILES=P0,P1,P2,P3,P4,P5

# =============================================================================
# Optional: Prometheus/Grafana
# =============================================================================
# GRAFANA_PASSWORD=admin
# PROMETHEUS_RETENTION_TIME=15d

# =============================================================================
# Optional: Upstream CDN Configuration
# =============================================================================
# APE_UPSTREAM_TIMEOUT=30
# APE_MAX_RETRIES=3
